  "click": {
    "fields": {
      "itemName": {"type": "string", "default": "new"},
      "roiFront": {"type": "roi", "default": "0,0,100,100"},
      "roiBack": {"type": "roi", "default": "0,0,100,100"},
      "description": {"type": "string", "default": ""}
    }
  },
  "swipe": {
    "fields": {
      "itemName": {"type": "string", "default": "new"},
      "roiFront": {"type": "roi", "default": "0,0,100,100"},
      "roiBack": {"type": "roi", "default": "0,0,100,100"},
